[server]
host = "0.0.0.0"
port = 3000
admin_password = "change-me"

[oauth]
client_id = "your-discord-client-id"
client_secret = "your-discord-client-secret"
redirect_uri = "https://proxy.example.com/api/auth/callback"
required_guild_id = "your-discord-guild-id"

[singbox]
binary_path = "/usr/local/bin/sing-box"
config_path = "data/singbox-config.json"
base_port = 10001
max_proxies = 20000
prebound_proxies = 500
binding_idle_secs = 300
watchdog_interval_secs = 60
restart_interval_mins = 0
memory_restart_mb = 3072

[database]
url = "postgresql://postgres:change-me@127.0.0.1:5432/zenproxy"

[validation]
url = "https://www.gstatic.com/generate_204"
fallback_url = "https://cp.cloudflare.com/generate_204"
timeout_secs = 10
concurrency = 200
interval_mins = 30
error_threshold = 10
max_rounds_per_run = 20
retry_invalid_per_run = 500
batch_size = 300
valid_recheck_hours = 24
new_proxy_percent = 70
valid_recheck_percent = 20
invalid_retry_percent = 10
binding_failure_threshold = 3

[quality]
interval_mins = 180
concurrency = 10
stale_hours = 72
max_checks_per_run = 200

[relay]
timeout_secs = 600

[subscription]
password = "change-subscription-password"
# URL subscriptions refresh automatically once a day. Set 0 only when you
# intentionally want to disable unattended refresh. Per-subscription settings
# may override this global default.
auto_refresh_interval_mins = 1440
orphaned_valid_grace_hours = 24
export_cache_secs = 60

# Proxy pool listeners (SOCKS5+HTTP auto-detect on same port)
# Can also be configured via env: ZENPROXY_PROXY_LISTENER=user:pass@0.0.0.0:1080
# Filters are encoded in the username at connect time:
#   user-country-US-residential:pass → US residential proxy
#   user-chatgpt-google:pass → ChatGPT+Google accessible proxy
#
# [[proxy_listener]]
# name = "default"
# listen = "0.0.0.0:1080"
# username = "myuser"
# password = "mypassword"
