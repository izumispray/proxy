CADDY_SITE_ADDRESS=http://localhost
HTTP_PORT=80
HTTPS_PORT=443

POSTGRES_DB=zenproxy
POSTGRES_USER=zenproxy
POSTGRES_PASSWORD=change-me

ZENPROXY_ADMIN_PASSWORD=change-me
ZENPROXY_OAUTH_CLIENT_ID=
ZENPROXY_OAUTH_CLIENT_SECRET=
ZENPROXY_OAUTH_REDIRECT_URI=http://localhost/api/auth/callback
ZENPROXY_OAUTH_REQUIRED_GUILD_ID=

RUST_LOG=zenproxy=info,tower_http=info

# Proxy pool listener (SOCKS5+HTTP on same port, auto-detect)
# Format: user:pass@listen_host:port
# Filters via username suffix at connect time: user-country-US-residential:pass
# ZENPROXY_PROXY_LISTENER=myuser:mypass@0.0.0.0:1080
